# ─────────────────────────────────────────────────────────────────────────────
# Albie Onboarding — Environment Variables
# Copy this file to .env and fill in your values.
# NEVER commit .env to git.
# ─────────────────────────────────────────────────────────────────────────────

# ── Email (Resend) ────────────────────────────────────────────────────────────
# Sign up at https://resend.com — free tier: 100 emails/day, 3 000/month
RESEND_API_KEY="re_..."
# Must match the email registered with Resend (sandbox) or any address after domain verification
ADMIN_EMAIL="you@yourcompany.com"
# 'sandbox' = send only to ADMIN_EMAIL; 'production' = send to hotel + BCC admin
EMAIL_MODE="sandbox"
# 'onboarding@resend.dev' until you verify a domain, then 'onboarding@yourdomain.com'
FROM_EMAIL="onboarding@resend.dev"

# ── AI URL Analysis ───────────────────────────────────────────────────────────
# OpenAI API Key — used by /api/analyze-url
# Get yours at https://platform.openai.com/api-keys
OPENAI_API_KEY="sk-..."

# ── Google Sheets Integration ─────────────────────────────────────────────────
# The ID of the target Google Sheet (found in the sheet's URL):
# https://docs.google.com/spreadsheets/d/{SHEET_ID}/edit
GOOGLE_SHEET_ID="1BxiMVs0XRA5nFMdKvBdBZjgmUUqptlbs74OgVE2upms"

# The entire Service Account JSON key file — paste as a single line.
# Generate it at: Google Cloud Console → IAM → Service Accounts → Keys → Add Key (JSON)
# Then share your Google Sheet with the service account's client_email (Editor access).
GOOGLE_SERVICE_ACCOUNT_JSON='{"type":"service_account","project_id":"...","private_key_id":"...","private_key":"-----BEGIN PRIVATE KEY-----\n...\n-----END PRIVATE KEY-----\n","client_email":"albie-sheets@YOUR_PROJECT.iam.gserviceaccount.com","client_id":"...","auth_uri":"https://accounts.google.com/o/oauth2/auth","token_uri":"https://oauth2.googleapis.com/token"}'
